{
  "name": "facebook-scraper-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Scaffolded Facebook page and Marketplace scraper platform built around Chrome DevTools attachment",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test tests/*.test.ts",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "validate": "bun run format && bun run typecheck && bun run lint && bun run test",
    "db:prepare": "bun run src/cli/db_prepare.ts",
    "smoke:live": "bun run src/cli/smoke.ts",
    "scrape:page-info": "bun run src/cli/scrape_page_info.ts",
    "scrape:page-posts": "bun run src/cli/scrape_page_posts.ts",
    "scrape:marketplace-search": "bun run src/cli/scrape_marketplace_search.ts",
    "scrape:marketplace-listing": "bun run src/cli/scrape_marketplace_listing.ts",
    "scrape:marketplace-seller": "bun run src/cli/scrape_marketplace_seller.ts",
    "scrape:marketplace-listings-bulk": "bun run src/cli/scrape_marketplace_listings.ts",
    "scrape:marketplace-sellers-bulk": "bun run src/cli/scrape_marketplace_sellers.ts",
    "scrape:group-info": "bun run src/cli/scrape_group_info.ts",
    "scrape:group-posts": "bun run src/cli/scrape_group_posts.ts",
    "scrape:group-post-detail": "bun run src/cli/scrape_group_post_detail.ts",
    "scrape:group-post-details-bulk": "bun run src/cli/scrape_group_post_details.ts",
    "db:cleanup": "bun run src/cli/cleanup.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mongodb": "^7.1.0",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.39.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
